	<Document>
		<name> StoGöt</name>
		<description>
			<![CDATA[ ]]>
		</description>
		<Folder>
			<name> Stationer</name>
			<Placemark>
				<name> Stockholm</name>
				<styleUrl> #icon-paddle-red</styleUrl>
				<Point>
					<coordinates>
						18.0580473,59.3302343,0.0
					</coordinates>
				</Point>
				<description>
					<![CDATA[ <div lang="sv"> <b>Stockholms</b> station eller central. Förändrinngarna <ol>
					 <li>Finlands HHtågena mot Åland och Helsingfors</li> <li>Estlands HHtågena via Åland till
					 Tallinn, kanske även Riga</li> <li>Moskva tåget</li> </ol> Om Hyperloop blir av så skyttel
					 via Arlanda till Norrtälje, Åland, Åbo<br> och Helsingfors </div> <div lang="fi">
					 <b>Tukholman</b> keskusasema. Muutokset <ol> <li>Finlands HHtågena kohti Ahvenanmaata ja
					 Helsinkiä</li> <li>Estlands HHtågena Ahvenanmaan kautta kohti Tallinnaa,<br> mahdollisesti
					 myös Riika</li> <li>Juna määränpäänä Tampere, juna pystyy vaihtamaan kiskoleveyttä<br>
					 Karjaalla, kuten jo nykyään automaattisesti tehdään Espanjassa</li> </ol> Jos Hyperloop
					 suunnitelma toteutuu niin sukkula kohti Arlanda, Norrtälje,<br> Ahvenanmaata, Turkua ja
					 Helsinkiä </div> <div lang="en"> <b>Stockholm</b> main railway station </div> ]]>
				</description>
			</Placemark>
			<Placemark>
				<name> Södertälje Syd</name>
				<styleUrl> #icon-paddle-red</styleUrl>
				<Point>
					<coordinates>
						17.6453733,59.1623797,0.0
					</coordinates>
				</Point>
				<description>
					<![CDATA[ <div lang="sv"><b>Södertälje Syd</b></div> <div lang="fi"><b>Södertälje
					 etelä</b></div> <div lang="en"><b>Södertälje south</b></div> ]]>
				</description>
			</Placemark>
			<Placemark>
				<name> Billsta</name>
				<styleUrl> #icon-paddle-grn-stars</styleUrl>
				<Point>
					<coordinates>
						17.5417328,59.075153900000004,0.0
					</coordinates>
				</Point>
				<description>
					<![CDATA[ <div lang="sv"> <b>Billsta</b> ligger söder om Järna. Järna är den nordligaste
					 punkten för Sverige<br> förhandlingens HH-bana. Sträckan Järna - Stockholm använder i<br>
					 förhandlingsresultatet den gamla banan </div> <div lang="fi"> <b>Billsta</b> sijaitsee
					 Järnasta etelään. Järna on pohjoisin<br> "Sverige förhandlingen" neuvottelun KN-rata
					 piste.<br> Rata Järna - Tukholma ajetaan vanhalla radalla </div> <div lang="en">
					 <b>Billsta</b> </div> ]]>
				</description>
			</Placemark>
