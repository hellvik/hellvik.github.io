<?xml version='1.0' encoding='UTF-8'?>
<kml xmlns='http://www.opengis.net/kml/2.2'>
	<Document>
		<name> G1</name>
		<description>
			<![CDATA[ ]]>
		</description>
		<Folder>
			<name> Untitled layer</name>
			<Placemark>
				<styleUrl> #icon-paddle-red</styleUrl>
				<name> Stockholm</name>
				<Point>
					<coordinates>
						18.0581975,59.3301249,0.0
					</coordinates>
				</Point>
				<description>
					<![CDATA[ <div lang="sv"> <b>Stockholms</b> station eller central. Förändrinngarna <ol>
					 <li>Finlands HHtågena mot Åland och Helsingfors</li> <li>Estlands HHtågena via Åland till
					 Tallinn, kanske även Riga</li> <li>Moskva tåget</li> </ol> Om Hyperloop blir av så skyttel
					 via Arlanda till Norrtälje, Åland, Åbo<br> och Helsingfors </div> <div lang="fi">
					 <b>Tukholman</b> keskusasema. Muutokset <ol> <li>Finlands HHtågena kohti Ahvenanmaata ja
					 Helsinkiä</li> <li>Estlands HHtågena Ahvenanmaan kautta kohti Tallinnaa,<br> mahdollisesti
					 myös Riika</li> <li>Juna määränpäänä Tampere, juna pystyy vaihtamaan kiskoleveyttä<br>
					 Karjaalla, kuten jo nykyään automaattisesti tehdään Espanjassa</li> </ol> Jos Hyperloop
					 suunnitelma toteutuu niin sukkula kohti Arlanda, Norrtälje,<br> Ahvenanmaata, Turkua ja
					 Helsinkiä </div> <div lang="en"> <b>Stockholm</b> main railway station </div> ]]>
				</description>
			</Placemark>
			<Placemark>
				<styleUrl> #icon-paddle-red</styleUrl>
				<name> Norrtälje</name>
				<Point>
					<coordinates>
						18.6849976,59.741055300000006,0.0
					</coordinates>
				</Point>
				<description>
					<![CDATA[ <div lang="sv"><b>Norrtälje</b> station (nya)<br>(planerad)</div> <div
					 lang="fi"><b>Norrtäljen</b> asema (uusi)<br>(suunniteltu)</div> <div
					 lang="en"><b>Norrtälje</b> station (new)<br>(planned)</div> ]]>
				</description>
			</Placemark>
			<Placemark>
				<styleUrl> #icon-paddle-red</styleUrl>
				<name> Kapellskär</name>
				<Point>
					<coordinates>
						19.06402587890625,59.71768089889866,0.0
					</coordinates>
				</Point>
				<description>
					<![CDATA[ <div lang="sv"><b>Kapellskärs</b> station<br>(planerad)</div> <div
					 lang="fi"><b>Kapellskärin</b> asema<br>(suunniteltu)</div> <div lang="en"><b>Kapellskär</b>
					 station<br>(planned)</div> ]]>
				</description>
			</Placemark>
			<Placemark>
				<styleUrl> #icon-paddle-blue</styleUrl>
				<name> Arlanda</name>
				<Point>
					<coordinates>
						17.9300681,59.650635300000005,0.0
					</coordinates>
				</Point>
				<description>
					<![CDATA[ <div lang="sv"> <b>Arlanda</b>. Buss från Norrtälje till Arlanda terminal 5,<br>
					 Stockholm Arlanda flygplats (ARN)<br> Om Hyperloop blir av sker följande <ol> <li>Arlanda
					 expressen ersätts med skyttel både från Stockholm Central<br> och Uppsala Central</li>
					 <li>Ny skyttel från Norrtälje</li> <li>Syttel mellan flygfältena Arlanda och
					 Helsingfors-Vanda</li> </ol> </div> <div lang="fi"> <b>Arlanda</b>. Bussi Norrtäljestä
					 Arlanda terminal 5,<br> Stockholm Arlanda lentokenttä (ARN)<br> Jos Hyperloop toteutuu niin
					 Norrtäljestä matka jatkuu suoraan lentokentälle<br> ja tästä sukkula kääntyy kohti
					 etelää ja Tukholmaa </div> <div lang="en"> <b>Arlanda</b>. Bus from Norrtälje to Arlanda
					 terminal 5,<br> Stockholm Arlanda airport (ARN) </div> ]]>
				</description>
			</Placemark>
		</Folder>
