		<Folder>
			<name> Untitled layer</name>
			<Placemark>
				<styleUrl> #icon-paddle-G</styleUrl>
				<name> Tabasalu</name>
				<Point>
					<coordinates>
						24.588947296142578,59.43447055948029,0.0
					</coordinates>
				</Point>
				<description>
					<![CDATA[ <div lang="sv"> <b>Tabasalu</b> station (Planerad). Tabasalu är enda station vars
					 geografiska<br> plats i presentationen ej är exakt definjerad. Att stationen behövs är<br>
					 troligt men beslutet var placera beror på de estniska myndigheterna.<br> Namnet "Tabasalu"
					 är ett arbetsnamn och antagligen ligger stationen<br> ej vidare nära Tabasalu centrum.
					 </div> <div lang="fi"> <b>Tabasalun</b> asema (Suunniteltu). Tabasalu on ainoa asema jonka<br>
					 maantieteellinen sijaint esityksessä ej ole tarkasti määritelty. Näyttää<br> selvältä
					 että asemaa tarvitaan mutta sijainti on virolaisten päättäjien<br> harteilla päättää
					 minne.<br> Nimi "Tabasalu" on työnimi eikä asema ole edes lähellä Tabasalun keskustaa.
					 </div> <div lang="en"> <b>Tabasalu</b>station (Planned) </div> ]]>
				</description>
			</Placemark>
